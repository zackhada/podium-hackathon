# PostgreSQL
POSTGRES_USER=podium
POSTGRES_PASSWORD=podium
POSTGRES_DB=podium
DATABASE_URL=postgresql://podium:podium@localhost:5432/podium

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# API
PORT=3001

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_OPENCLAW_URL=http://localhost:18789

# VAPI (voice calls)
# Get your API key at dashboard.vapi.ai
VAPI_API_KEY=REPLACE_ME
# Create a phone number at dashboard.vapi.ai → Phone Numbers, then paste the ID here
VAPI_PHONE_NUMBER_ID=REPLACE_ME
# Your publicly accessible URL for VAPI webhooks (use ngrok for local dev)
# e.g. https://abc123.ngrok.io  — VAPI will POST to {NEXT_PUBLIC_BASE_URL}/api/vapi/webhook
NEXT_PUBLIC_BASE_URL=http://localhost:3000
